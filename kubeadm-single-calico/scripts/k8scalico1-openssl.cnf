# k8scalico1-openssl.cnf
[ req ]
default_bits       = 4096
prompt             = no
default_md         = sha256
req_extensions     = req_ext
distinguished_name = dn

[ dn ]
C  = Fr
O  = dfitc
CN = k8scalico1.app.teknews.cloud

[ req_ext ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = k8scalico1.app.teknews.cloud
DNS.2 = k8scalico1
DNS.3 = gundamapp
IP.1  = 192.168.56.16
